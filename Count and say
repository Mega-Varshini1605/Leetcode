function countAndSay(n: number): string {
    if (n === 1) return "1";

    let result = "1";

    // n-1 times process pannanum (since n=1 is already "1")
    for (let i = 2; i <= n; i++) {
        let currentBuild = "";
        let j = 0;

        while (j < result.length) {
            let count = 1;
            let char = result[j];

            // Adutha adutha characters same-a nu check pannu
            while (j + 1 < result.length && result[j] === result[j + 1]) {
                count++;
                j++;
            }

            // Count-ahum character-ahum serthu ezhudhu
            currentBuild += count.toString() + char;
            j++;
        }
        
        result = currentBuild; // Intha step mudinja apram result updated
    }

    return result;
}
