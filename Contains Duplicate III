import java.util.*;

class Solution {
    public boolean containsNearbyAlmostDuplicate(int[] nums, int indexDiff, int valueDiff) {
        if (nums == null || nums.length < 2 || indexDiff < 1 || valueDiff < 0) return false;

        // Map to store: Bucket ID -> Value
        Map<Long, Long> buckets = new HashMap<>();
        long width = (long) valueDiff + 1;

        for (int i = 0; i < nums.length; i++) {
            long val = (long) nums[i];
            long bucketId = getBucketId(val, width);

            // 1. Same bucket: difference is definitely <= valueDiff
            if (buckets.containsKey(bucketId)) return true;

            // 2. Check adjacent buckets
            if (buckets.containsKey(bucketId - 1) && Math.abs(val - buckets.get(bucketId - 1)) < width) return true;
            if (buckets.containsKey(bucketId + 1) && Math.abs(val - buckets.get(bucketId + 1)) < width) return true;

            // 3. Put current value in bucket
            buckets.put(bucketId, val);

            // 4. Maintain sliding window of size indexDiff
            if (i >= indexDiff) {
                buckets.remove(getBucketId((long) nums[i - indexDiff], width));
            }
        }

        return false;
    }

    private long getBucketId(long val, long width) {
        // Adjust for negative numbers so they map correctly to buckets
        return val < 0 ? (val + 1) / width - 1 : val / width;
    }
}
