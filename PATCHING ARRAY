class Solution {
    public int minPatches(int[] nums, int n) {
        long miss = 1;
        int patches = 0;
        int i = 0;

        while (miss <= n) {
            if (i < nums.length && nums[i] <= miss) {
                // If the current number can help extend the range
                miss += nums[i];
                i++;
            } else {
                // If there's a gap, patch it with the 'miss' value itself
                miss += miss;
                patches++;
            }
        }
        
        return patches;
    }
}
