class Solution {
    public int divide(int dividend, int divisor) {
        // Handle overflow case: -2^31 / -1 = 2^31 (exceeds Integer.MAX_VALUE)
        if (dividend == Integer.MIN_VALUE && divisor == -1) {
            return Integer.MAX_VALUE;
        }

        // Determine the sign of the result
        boolean negative = (dividend < 0) ^ (divisor < 0);

        // Work with negative numbers to avoid overflow when converting MIN_VALUE to positive
        long longDividend = Math.abs((long) dividend);
        long longDivisor = Math.abs((long) divisor);

        int quotient = 0;
        
        // Exponentially subtract the divisor
        while (longDividend >= longDivisor) {
            long tempDivisor = longDivisor;
            int multiple = 1;
            
            // Double the divisor and the multiple as long as it fits
            while (longDividend >= (tempDivisor << 1)) {
                tempDivisor <<= 1;
                multiple <<= 1;
            }
            
            longDividend -= tempDivisor;
            quotient += multiple;
        }

        return negative ? -quotient : quotient;
    }
}
