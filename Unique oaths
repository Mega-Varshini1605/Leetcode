class Solution {
    public int uniquePaths(int m, int n) {
        // We only need one row of DP to store the previous results
        int[] dp = new int[n];
        
        // Initialize the first row: there's only 1 way to stay in any cell of the first row
        for (int j = 0; j < n; j++) {
            dp[j] = 1;
        }

        // Fill the rest of the "grid" row by row
        for (int i = 1; i < m; i++) {
            for (int j = 1; j < n; j++) {
                // The new value for dp[j] = current dp[j] (from above) + dp[j-1] (from left)
                dp[j] += dp[j - 1];
            }
        }

        return dp[n - 1];
    }
}
