import java.util.*;

class Solution {
    public List<List<Integer>> getSkyline(int[][] buildings) {
        List<List<Integer>> result = new ArrayList<>();
        List<int[]> heights = new ArrayList<>();

        // 1. Separate each building into two events: start and end
        for (int[] b : buildings) {
            // Use negative height for start to distinguish from end and sort correctly
            heights.add(new int[]{b[0], -b[2]}); 
            heights.add(new int[]{b[1], b[2]});
        }

        // 2. Sort events by x-coordinate
        // If x is same, process the taller start first (negative heights handle this)
        Collections.sort(heights, (a, b) -> {
            if (a[0] != b[0]) return a[0] - b[0];
            return a[1] - b[1];
        });

        // 3. Max-Heap to keep track of current building heights
        PriorityQueue<Integer> pq = new PriorityQueue<>(Collections.reverseOrder());
        pq.offer(0); // Ground level
        int prevMaxHeight = 0;

        for (int[] h : heights) {
            if (h[1] < 0) {
                // Building starts
                pq.offer(-h[1]);
            } else {
                // Building ends
                pq.remove(h[1]);
            }

            int currentMaxHeight = pq.peek();
            // If the max height changes, we found a key point
            if (currentMaxHeight != prevMaxHeight) {
                result.add(Arrays.asList(h[0], currentMaxHeight));
                prevMaxHeight = currentMaxHeight;
            }
        }

        return result;
    }
}
