class Solution {
    public int findMin(int[] nums) {
        int left = 0;
        int right = nums.length - 1;

        while (left < right) {
            int mid = left + (right - left) / 2;

            if (nums[mid] < nums[right]) {
                // Minimum must be in the left half (including mid)
                right = mid;
            } else if (nums[mid] > nums[right]) {
                // Minimum must be in the right half (excluding mid)
                left = mid + 1;
            } else {
                // nums[mid] == nums[right]: We don't know which side to pick.
                // Safely reduce the search space by moving the right pointer.
                right--;
            }
        }
        
        return nums[left];
    }
}
