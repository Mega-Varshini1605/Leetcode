class Solution {
    public int maxProfit(int k, int[] prices) {
        int n = prices.length;
        if (n <= 1 || k == 0) return 0;

        // Optimization: If k is large enough, it's like having unlimited transactions
        if (k >= n / 2) {
            int maxProfit = 0;
            for (int i = 1; i < n; i++) {
                if (prices[i] > prices[i - 1]) {
                    maxProfit += prices[i] - prices[i - 1];
                }
            }
            return maxProfit;
        }

        // buy[j] = max profit after j-th buy
        // sell[j] = max profit after j-th sell
        int[] buy = new int[k + 1];
        int[] sell = new int[k + 1];
        
        // Initialize buy states to negative infinity
        for (int i = 0; i <= k; i++) {
            buy[i] = Integer.MIN_VALUE;
        }

        for (int price : prices) {
            for (int j = 1; j <= k; j++) {
                // To buy the j-th stock: balance after (j-1)th sell minus current price
                buy[j] = Math.max(buy[j], sell[j - 1] - price);
                // To sell the j-th stock: balance after j-th buy plus current price
                sell[j] = Math.max(sell[j], buy[j] + price);
            }
        }

        return sell[k];
    }
}
